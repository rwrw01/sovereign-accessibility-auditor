{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "references": [
    { "path": "packages/shared" },
    { "path": "packages/api" },
    { "path": "packages/dashboard" },
    { "path": "packages/scanners/multi-engine" },
    { "path": "packages/scanners/visual-regression" },
    { "path": "packages/scanners/behavioral" },
    { "path": "packages/scanners/a11y-tree" },
    { "path": "packages/scanners/touch-targets" },
    { "path": "packages/scanners/screenreader" },
    { "path": "packages/scanners/cognitive" },
    { "path": "packages/report-generator" }
  ],
  "exclude": ["node_modules", "dist", ".turbo"]
}
